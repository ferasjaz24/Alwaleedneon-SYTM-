rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Common helper functions
    function isSignedIn() {
      return true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Employees Collection Rules
    match /employees/{employeeId} {
      allow read, write: if true;
    }

    // Clients Collection Rules
    match /clients/{clientId} {
      allow read, write: if isSignedIn();
    }

    // Deductions Collection Rules
    match /deductions/{deductionId} {
      allow read, write: if isSignedIn();
    }

    // Salaries Collection Rules
    match /salaries/{salaryId} {
      allow read, write: if isSignedIn();
    }

    // Leaves Collection Rules
    match /leaves/{leaveId} {
      allow read, write: if isSignedIn();
    }

    // Vacations Collection Rules
    match /vacations/{vacationId} {
      allow read, write: if isSignedIn();
    }

    // Activity Logs Collection Rules
    match /activity_logs/{logId} {
      allow read, write: if isSignedIn();
    }

    // Clearances Collection Rules
    match /clearances/{clearanceId} {
      allow read, write: if true;
    }

    // Employee Docs Collection Rules
    match /employee-docs/{docId} {
      allow read, write: if isSignedIn();
    }

    // Vehicle Docs Collection Rules
    match /vehicle-docs/{docId} {
      allow read, write: if isSignedIn();
    }

    // Doc Activity Logs Collection Rules
    match /doc-activity-logs/{logId} {
      allow read, write: if isSignedIn();
    }

    // Projects Collection Rules
    match /projects/{projectId} {
      allow read, write: if isSignedIn();
    }

    // Customers Collection Rules
    match /customers/{customerId} {
      allow read, write: if isSignedIn();
    }

    // Pricing Studies Collection Rules
    match /pricing_studies/{studyId} {
      allow read, write: if isSignedIn();
    }

    // Production Orders Collection Rules
    match /production_orders/{orderId} {
      allow read, write: if isSignedIn();
    }

    // Inventory Collection Rules
    match /inventory/{itemId} {
      allow read, write: if isSignedIn();
    }

    // Sales Quotations Collection Rules
    match /sales_quotations/{quoteId} {
      allow read, write: if isSignedIn();
    }

    // Warehouse Items Collection Rules
    match /warehouse_items/{itemId} {
      allow read, write: if isSignedIn();
    }

    // Tasks Collection Rules
    match /tasks/{taskId} {
      allow read, write: if isSignedIn();
    }

    // Payments Collection Rules
    match /payments/{paymentId} {
      allow read, write: if isSignedIn();
    }

    // Journal Entries Collection Rules
    match /journal_entries/{entryId} {
      allow read, write: if true;
    }

    match /revenues/{docId} {
      allow read, write: if true;
    }

    match /expenses/{docId} {
      allow read, write: if true;
    }

    match /dashboard_metrics/{docId} {
      allow read, write: if true;
    }

    // Login Logs Collection Rules
    match /login_logs/{logId} {
      allow read, write: if true;
    }

    // System Settings Collection Rules
    match /system_settings/{settingId} {
      allow read, write: if isSignedIn();
    }

    // Global safety net catch-all deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
